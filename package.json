    "react-dom": "^19.2.7",
    "use-local-storage-state": "^19.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/carbon": "^1.2.24",
    "@tanstack/router-plugin": "^1.168.19",
